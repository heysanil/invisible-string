{
  "name": "invisible-string",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*",
    "tests/*",
    "e2e"
  ],
  "scripts": {
    "typecheck": "bun run --filter='./apps/*' --filter='./packages/*' --filter='./tests/*' typecheck && tsc -p scripts",
    "test": "bun test",
    "dev": "bun run scripts/dev.ts",
    "dev:down": "docker compose down",
    "slack:manifest": "bun run scripts/slack-manifest.ts"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "typescript": "^6.0.3"
  }
}
