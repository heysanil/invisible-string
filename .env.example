# invisible-string — environment variables (copy to .env; never commit .env)

# ── Postgres ────────────────────────────────────────────────────────────────
# Product data (control plane + Better Auth). Compose creates the "product" DB.
DATABASE_URL=postgres://dev:dev@localhost:5432/product
# eve durability world (@workflow/world-postgres). Compose creates the "world" DB.
WORLD_DATABASE_URL=postgres://dev:dev@localhost:5432/world

# ── Secrets ─────────────────────────────────────────────────────────────────
# Master key for AES-256-GCM envelope encryption of secrets at rest
# (MCP auth configs, integration credentials, trigger secrets).
# Generate: openssl rand -base64 32
ENCRYPTION_MASTER_KEY=
# HMAC secret for platform-signed JWTs (dispatcher -> compiled channel,
# control plane <-> worker /internal/* auth).
# Generate: openssl rand -base64 32
PLATFORM_JWT_SECRET=

# ── Object storage (S3-compatible; MinIO in dev) ────────────────────────────
# Build-artifact tarballs + trigger file payloads live in the "artifacts" bucket.
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY_ID=dev
S3_SECRET_ACCESS_KEY=devdevdev
S3_BUCKET=artifacts
S3_REGION=us-east-1

# ── Model providers (platform-owned; exactly one injected per compiled agent) ─
OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=

# ── Better Auth ─────────────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000
# Require verified email before sign-in (1 to enable). Default off: local/CI
# stacks have no mailer. Enable in production before trust decisions.
# AUTH_REQUIRE_EMAIL_VERIFICATION=1

# ── Web app (Vite; only VITE_-prefixed vars reach the browser bundle) ───────
# Control-plane origin the SPA calls for API + Better Auth. Defaults to
# http://localhost:3000 when unset.
VITE_API_URL=http://localhost:3000
# Set to 1 to render the chat surface from canned fixtures with no backend
# (design/E2E preview; bypasses the auth gate). Leave unset in normal dev.
# VITE_FIXTURE_MODE=1

# ── Observability (optional) ─────────────────────────────────────────────────
# Floor log level for the structured JSON logger (debug|info|warn|error).
# Defaults to info. GET /internal/metrics (worker-secret-guarded) and
# GET /api/health?deep=1 need no extra config.
# LOG_LEVEL=info

# ── Worker pool + per-worker identity (Phase 3) ──────────────────────────────
# Shared secret the worker plane presents on /internal/* (register/heartbeat/
# dispatch). Generate: openssl rand -base64 32
WORKER_SHARED_SECRET=
# shared-secret (default) keeps the single-credential Phase-1 behaviour;
# worker-token mints a per-worker HS256 session token at register (rotated on
# heartbeat) + a per-call dispatch token (audience worker:<id>) on ensure-agent.
# WORKER_AUTH_MODE=shared-secret
# Heartbeat freshness window before the sweeper marks a worker dead (ms).
# WORKER_HEARTBEAT_TTL_MS=30000
# Dead-worker sweep interval; defaults to the heartbeat TTL.
# WORKER_SWEEP_INTERVAL_MS=30000
# Per-worker agent-slot cap the scheduler enforces when a worker omits maxAgents.
# SCHEDULER_MAX_AGENTS_PER_WORKER=20
# Registration allowlist: only these worker ids may register (comma-separated
# UUIDs). Unset = any id presenting the shared secret may register (dev only).
# WORKER_ALLOWED_IDS=
# Worker registration/dispatch normally requires https:// addresses
# (secret-bearing calls). Local dev workers advertise http://localhost — this
# opt-in lets registration succeed. Local/CI only, never production.
ALLOW_INSECURE_WORKER_TRANSPORT=1

# ── Worker app (apps/worker) ─────────────────────────────────────────────────
# Control-plane base URL for register/heartbeat/deregister. Required — no
# default (mirrors the control plane's own :3000 from BETTER_AUTH_URL above).
CONTROL_PLANE_URL=http://localhost:3000
# Stable worker identity; random UUID per boot when unset.
# WORKER_ID=
# Base URL this worker advertises to the control plane (default http://localhost:<PORT>).
# PUBLIC_URL=
# Extracted-artifact cache root. Default /var/lib/agents suits the Linux
# worker image but is not writable on macOS — `bun run dev` bootstrap points
# fresh .env files at <repo>/.dev/agent-cache (gitignored) instead.
# ARTIFACT_CACHE_DIR=/var/lib/agents
# LRU cap for extracted artifacts (bytes, default 20 GiB).
# ARTIFACT_CACHE_MAX_BYTES=21474836480
# Stop agent processes idle this long (ms, default 15 min).
# AGENT_IDLE_STOP_MS=900000
# Max wait for /eve/v1/health after agent spawn (ms, default 60 s).
# AGENT_READY_TIMEOUT_MS=60000
# Node runtime used to launch compiled agents (eve needs Node 24).
# WORKER_NODE_BIN=node

# ── Sandbox reaper (worker-side; needs a docker daemon) ──────────────────────
# Stops eve-session sandboxes idle past the window (design correction 4). Off by
# default; eve gives sandboxes no idle timeout of its own.
# SANDBOX_REAPER_ENABLED=1
# SANDBOX_IDLE_STOP_MS=1800000
# SANDBOX_LABEL=eve.session
# DOCKER_BIN=docker

# ── Triggers + Slack app (Phase 3) ───────────────────────────────────────────
# Webhook/form ingress works with no extra config (POST /t/:token). The Slack
# app is optional — only needed to install the platform Slack integration.
# SLACK_CLIENT_ID=
# SLACK_CLIENT_SECRET=
# SLACK_SIGNING_SECRET=
# OAuth bot scopes (comma/space-separated; has a sensible default).
# SLACK_BOT_SCOPES=
# Public origin the app is reached at — the Slack OAuth redirect + webhook
# ingress URLs derive from it. Falls back to BETTER_AUTH_URL, then localhost:3000.
# PUBLIC_APP_URL=http://localhost:3000
# Override the Slack Web API / consent bases (tests point these at a stub server).
# SLACK_API_BASE_URL=https://slack.com/api
# SLACK_AUTHORIZE_URL=https://slack.com/oauth/v2/authorize
# Ingress rate limits (fixed window per minute).
# TRIGGER_RATE_LIMIT_PER_TOKEN_PER_MIN=60
# TRIGGER_RATE_LIMIT_PER_IP_PER_MIN=120

# ── Builder copilot (Phase 4) ────────────────────────────────────────────────
# The copilot socket (WS /workspaces/:id/copilot) mounts only when a provider
# key exists: OPENROUTER_API_KEY for the default openrouter provider (Claude
# via OpenRouter on the platform key), ANTHROPIC_API_KEY for the direct path.
# COPILOT_PROVIDER=openrouter            # openrouter (default) | anthropic
# COPILOT_MODEL=anthropic/claude-sonnet-5
# COPILOT_MAX_SESSIONS=2                 # concurrent sessions per workspace
# COPILOT_MAX_OUTPUT_TOKENS=8192         # per-turn model output budget
# COPILOT_MAX_STEPS=12                   # per-turn tool-loop round-trip cap
# Deterministic scripted fake LLM (tests only; JSON script) — when set the
# socket mounts without any provider key and never calls a real model.
# COPILOT_FAKE_SCRIPT=
# Real-model copilot smoke test gate (with OPENROUTER_API_KEY):
# COPILOT_KEYED=1

# ── docker-compose host-port overrides (optional) ───────────────────────────
POSTGRES_PORT=5432
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
DEX_PORT=5556

# ── Tests ───────────────────────────────────────────────────────────────────
# DB-dependent tests run only when set (integration stage provides it);
# they skip cleanly otherwise.
TEST_DATABASE_URL=
